# ─── n8n — Workflow Automation ────────────────────────────────────────────────
# N8N_ENCRYPTION_KEY and RUNNERS_AUTH_TOKEN are auto-generated by start.sh on
# first run and written back here. Do not share this file.
# See: docs/env-conventions.md

# ─── Image ────────────────────────────────────────────────────────────────────
# Pin to a specific version for reproducibility, e.g. 1.85.0
# See: https://github.com/n8n-io/n8n/releases
N8N_VERSION=stable

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Root superuser (used only by postgres init and healthcheck)
POSTGRES_USER=n8n_root
POSTGRES_PASSWORD=changeme
POSTGRES_DB=n8n

# Non-root application user (used by n8n at runtime)
# Must differ from POSTGRES_USER.
POSTGRES_NON_ROOT_USER=n8n_user
POSTGRES_NON_ROOT_PASSWORD=changeme

# ─── Security (auto-generated on first start) ────────────────────────────────
# N8N_ENCRYPTION_KEY: encrypts all stored credentials in the database.
# Losing this key means losing access to all stored credentials.
# WARNING: Never change after first run. See: docs/env-conventions.md
N8N_ENCRYPTION_KEY=                       # auto-generated by start.sh on first run

# RUNNERS_AUTH_TOKEN: shared secret between n8n and its task runner sidecars.
RUNNERS_AUTH_TOKEN=                       # auto-generated by start.sh on first run

# ─── Application ──────────────────────────────────────────────────────────────
# Host port exposed on localhost.
N8N_PORT_HOST=5678

N8N_HOST=localhost
N8N_PROTOCOL=http

# WEBHOOK_URL must match the public address n8n is reachable at.
# Webhook nodes will embed this URL in their trigger URLs.
WEBHOOK_URL=http://localhost:5678/

# Only set this if running locally, behind a firewall and using the name-proxy
# N8N_SECURE_COOKIE=false

# ─── Locale / timezone ────────────────────────────────────────────────────────
# Used by Schedule Trigger nodes — must match your local timezone.
# See: docs/env-conventions.md
GENERIC_TIMEZONE=America/Chicago
TZ=America/Chicago

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: error | warn | info | verbose | debug | silent
N8N_LOG_LEVEL=info

# ─── Execution data retention ─────────────────────────────────────────────────
# Prune finished execution records older than 14 days (336 hours) or
# when total count exceeds 50 000, whichever comes first.
# Prevents the database from growing unbounded.
# EXECUTIONS_DATA_PRUNE, EXECUTIONS_DATA_MAX_AGE, and
# EXECUTIONS_DATA_PRUNE_MAX_COUNT are set in docker-compose.yml.

# ─── Data paths (optional) ───────────────────────────────────────────────────
# Override where Docker stores persistent data on the host.
# Leave unset to use the defaults shown below.
# See: docs/env-conventions.md
#N8N_APP_DATA_PATH=./data/n8n
#N8N_DB_DATA_PATH=./data/postgres
#N8N_REDIS_DATA_PATH=./data/redis

# ─── Mail / SMTP (optional) ───────────────────────────────────────────────────
# Required to send user invitation and password-reset emails.
# Without it, share credentials and invite links manually.
# Docs: https://docs.n8n.io/hosting/configuration/configuration-examples/smtp/
# See: docs/env-conventions.md for SMTP guidance.
#N8N_EMAIL_MODE=smtp
#N8N_SMTP_HOST=smtp.example.com
#N8N_SMTP_PORT=587
#N8N_SMTP_USER=
#N8N_SMTP_PASS=
#N8N_SMTP_SENDER=n8n@example.com
#N8N_SMTP_SSL=false
