# ─── Plane — Project Management ───────────────────────────────────────────────
# Secrets marked GENERATE_ME are auto-generated by start.sh on first run.
# DATABASE_URL and AMQP_URL are also derived on first run from the values below.
# Do not share this file — it contains database and storage credentials.
# See: docs/env-conventions.md

# ─── Release version ──────────────────────────────────────────────────────────
# Pin to a specific release for reproducibility.
# See: https://github.com/makeplane/plane/releases
APP_RELEASE=v1.3.0

# ─── Host port ────────────────────────────────────────────────────────────────
# Port exposed on the host. Change if 8100 conflicts with another service.
LISTEN_HTTP_PORT=8100

# ─── Application ──────────────────────────────────────────────────────────────
# WEB_URL must be the full URL users will access (including port if non-standard).
WEB_URL=http://localhost:8100
APP_DOMAIN=localhost
CORS_ALLOWED_ORIGINS=http://localhost:8100
DEBUG=0

# Number of Gunicorn workers for the API. Formula: 2 × CPU cores + 1.
# Use 2 for local dev; increase for production with more CPU cores.
GUNICORN_WORKERS=2

# API rate limit per key. Format: <count>/<period> where period is second/minute/hour/day.
API_KEY_RATE_LIMIT=60/minute

# ─── Django secret key (auto-generated on first run) ─────────────────────────
# Changing this after first run will invalidate all active sessions.
# See: docs/env-conventions.md
SECRET_KEY=                               # auto-generated by start.sh on first run

# ─── Live collaboration server secret (auto-generated on first run) ───────────
LIVE_SERVER_SECRET_KEY=                   # auto-generated by start.sh on first run

# Internal API base URL — do not change unless you rename the api service.
API_BASE_URL=http://api:8000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
PGHOST=plane-db
PGDATABASE=plane
POSTGRES_USER=plane
POSTGRES_DB=plane
POSTGRES_PORT=5432
PGDATA=/var/lib/postgresql/data
# Password auto-generated on first run:
POSTGRES_PASSWORD=                        # auto-generated by start.sh on first run
# Full connection URL — derived from the values above on first run:
DATABASE_URL=                             # derived by start.sh on first run

# ─── Valkey / Redis ───────────────────────────────────────────────────────────
REDIS_HOST=plane-redis
REDIS_PORT=6379
# No auth on the internal Redis instance; URL is static:
REDIS_URL=redis://plane-redis:6379/

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_VHOST=plane
# Password auto-generated on first run:
RABBITMQ_PASSWORD=                        # auto-generated by start.sh on first run
# Full AMQP URL — derived from the values above on first run:
AMQP_URL=                                 # derived by start.sh on first run

# ─── MinIO / S3-compatible object storage ─────────────────────────────────────
# MinIO uses these as its root credentials (set once at container creation).
# Changing them after first run requires resetting the MinIO volume.
USE_MINIO=1
MINIO_ENDPOINT_SSL=0
# AWS_REGION is unused when USE_MINIO=1 but required by the SDK; leave blank.
AWS_REGION=
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
# Credentials auto-generated on first run:
AWS_ACCESS_KEY_ID=                        # auto-generated by start.sh on first run
AWS_SECRET_ACCESS_KEY=                    # auto-generated by start.sh on first run

# ─── Proxy ────────────────────────────────────────────────────────────────────
# Maximum upload file size in bytes (default 5 MB = 5242880).
FILE_SIZE_LIMIT=5242880
# Internal listen address for the proxy container — do not change.
SITE_ADDRESS=:80

# ─── Data paths (optional) ───────────────────────────────────────────────────
# Override where Docker stores persistent data on the host.
# Leave unset to use the defaults shown below.
# See: docs/env-conventions.md
#PLANE_DB_DATA_PATH=./data/postgres
#PLANE_REDIS_DATA_PATH=./data/redis
#PLANE_MQ_DATA_PATH=./data/rabbitmq
#PLANE_UPLOADS_PATH=./data/uploads
#PLANE_LOGS_MIGRATOR_PATH=./data/logs/migrator
#PLANE_LOGS_API_PATH=./data/logs/api
#PLANE_LOGS_WORKER_PATH=./data/logs/worker
#PLANE_LOGS_BEAT_PATH=./data/logs/beat
#PLANE_PROXY_CONFIG_PATH=./data/proxy/config
#PLANE_PROXY_DATA_PATH=./data/proxy/data

# ─── Email / SMTP (optional) ─────────────────────────────────────────────────
# Required to send notifications, magic links, and mention alerts.
# Docs: https://docs.plane.so/self-hosting/govern/communication-with-smtp
# See: docs/env-conventions.md for SMTP guidance.
#EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#EMAIL_HOST=smtp.example.com
#EMAIL_HOST_USER=
#EMAIL_HOST_PASSWORD=
#EMAIL_PORT=587
#EMAIL_USE_TLS=True
#EMAIL_USE_SSL=False
#DEFAULT_FROM_EMAIL=plane@example.com
# Plane uses EMAIL_FROM as the envelope sender; DEFAULT_FROM_EMAIL appears in the From header.
# Set both to the same address unless you need them to differ.
#EMAIL_FROM=plane@example.com
