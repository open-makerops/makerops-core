# ─── Outline — Collaborative Knowledge Base ───────────────────────────────────
# SECRET_KEY and UTILS_SECRET are auto-generated by start.sh on first run.
# WARNING: Do not change them after first run — they encrypt stored data.
#
# Auth is required before any user can sign in. Configure OIDC once Keycloak
# is running (infrastructure/keycloak). SMTP magic-link is an alternative.
# See: docs/env-conventions.md

# ─── Image ────────────────────────────────────────────────────────────────────
# Pin to a specific release tag for reproducibility.
# See: https://hub.docker.com/r/outlinewiki/outline/tags
OUTLINE_VERSION=latest

# ─── Application ──────────────────────────────────────────────────────────────
# URL must match the address used to reach Outline (including port).
# Changing this after first run requires updating links stored in the database.
URL=http://localhost:3001

# Port exposed on the host. 3000 is taken by the triggerdotdev_sandbox Next.js app.
OUTLINE_PORT_HOST=3001

# ─── Secrets ──────────────────────────────────────────────────────────────────
# Auto-generated by start.sh on first run. Never change after first start.
SECRET_KEY=OVERWRITE_ME
UTILS_SECRET=OVERWRITE_ME

# ─── Database ─────────────────────────────────────────────────────────────────
# Password for the outline PostgreSQL user. Auto-generated on first run.
# DATABASE_URL is assembled in docker-compose.yml from this value.
DB_PASSWORD=OVERWRITE_ME
# The local Postgres container has no SSL configured; disable it to prevent
# Outline from crash-looping with "server does not support SSL connections".
PGSSLMODE=disable

# ─── File storage (Garage / S3) ───────────────────────────────────────────────
# Credentials are auto-populated from infrastructure/garage/.env by start.sh.
# AWS_S3_UPLOAD_BUCKET_URL is the address the Outline container uses to reach
# Garage for uploads, and the base for presigned download URLs. On WSL2 /
# Docker Desktop, host.docker.internal resolves correctly from both the
# container and the browser. Change to your machine's LAN IP for remote access.
FILE_STORAGE=s3
AWS_ACCESS_KEY_ID=                           # auto-populated from infrastructure/garage/.env
AWS_SECRET_ACCESS_KEY=                       # auto-populated from infrastructure/garage/.env
AWS_REGION=garage
AWS_S3_UPLOAD_BUCKET_NAME=outline
AWS_S3_UPLOAD_BUCKET_URL=http://host.docker.internal:3900
AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_ACL=private

# ─── Auth — OIDC (Keycloak) ───────────────────────────────────────────────────
# Primary auth method for this stack. Fill in once Keycloak is running.
# OIDC_AUTH_URI is browser-facing — use http://localhost:8080/...
# OIDC_TOKEN_URI and OIDC_USERINFO_URI are server-to-server (Outline → Keycloak)
#   — use http://host.docker.internal:8080/... so the container can reach Keycloak.
# Realm path template: /realms/<realm>/protocol/openid-connect/{auth,token,userinfo}
#OIDC_CLIENT_ID=outline
#OIDC_CLIENT_SECRET=
#OIDC_AUTH_URI=http://localhost:8080/realms/master/protocol/openid-connect/auth
#OIDC_TOKEN_URI=http://host.docker.internal:8080/realms/master/protocol/openid-connect/token
#OIDC_USERINFO_URI=http://host.docker.internal:8080/realms/master/protocol/openid-connect/userinfo
#OIDC_DISPLAY_NAME=Keycloak
#OIDC_USERNAME_CLAIM=preferred_username

# ─── Auth — SMTP / magic-link (optional) ──────────────────────────────────────
# Enables email-based magic-link sign-in as a fallback or standalone auth method.
# See: docs/env-conventions.md for SMTP guidance.
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USERNAME=
#SMTP_PASSWORD=
#SMTP_FROM_EMAIL=outline@example.com
#SMTP_SECURE=true

# ─── Auth — OAuth (optional alternatives) ─────────────────────────────────────
# Uncomment one or more to enable additional sign-in options.
#SLACK_CLIENT_ID=
#SLACK_CLIENT_SECRET=
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=

# ─── Locale / timezone ────────────────────────────────────────────────────────
# See: docs/env-conventions.md
TZ=America/Chicago
DEFAULT_LANGUAGE=en_US

# ─── Data paths (optional) ────────────────────────────────────────────────────
# Override where Docker stores persistent data on the host.
# Leave unset to use the defaults shown below.
# See: docs/env-conventions.md
#OUTLINE_DB_DATA_PATH=./data/postgres
#OUTLINE_REDIS_DATA_PATH=./data/redis

# ─── Logging (optional) ───────────────────────────────────────────────────────
#LOG_LEVEL=info
