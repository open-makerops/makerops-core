# ─── trigger.dev v4 — Background Jobs & Workflow Execution ───────────────────
# App secrets are auto-generated by start.sh on first run and written back here.
# Do not share this file.
# See: docs/env-conventions.md

# ─── Image versions ───────────────────────────────────────────────────────────
# Pin all trigger.dev images together (webapp + supervisor).
# See: https://github.com/triggerdotdev/trigger.dev/releases
TRIGGER_IMAGE_TAG=v4.4.6
POSTGRES_IMAGE_TAG=16
REDIS_IMAGE_TAG=7
ELECTRIC_IMAGE_TAG=1.2.4
CLICKHOUSE_IMAGE_TAG=latest
REGISTRY_IMAGE_TAG=2
DOCKER_PROXY_IMAGE_TAG=latest

# ─── Host port ────────────────────────────────────────────────────────────────
LISTEN_PORT=3040

# ─── Application URL ──────────────────────────────────────────────────────────
# Must match the URL used in the browser.
# For remote/tunnel access, change TRIGGER_DOMAIN to the public host.
TRIGGER_PROTOCOL=http
TRIGGER_DOMAIN=localhost:3040
# Derived by start.sh from TRIGGER_PROTOCOL + TRIGGER_DOMAIN:
APP_ORIGIN=GENERATE_ME
LOGIN_ORIGIN=GENERATE_ME
API_ORIGIN=GENERATE_ME

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_DB=trigger
# Password auto-generated on first run:
POSTGRES_PASSWORD=GENERATE_ME
# DATABASE_URL and DIRECT_URL are derived by start.sh from the values above.
DATABASE_URL=GENERATE_ME
DIRECT_URL=GENERATE_ME

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# TLS is disabled because Redis runs on an internal Docker network.
REDIS_TLS_DISABLED=true

# ─── ClickHouse ───────────────────────────────────────────────────────────────
# Run analytics and replication backend. Added in v4.
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=GENERATE_ME
# Connection URLs derived by start.sh:
CLICKHOUSE_URL=GENERATE_ME
RUN_REPLICATION_CLICKHOUSE_URL=GENERATE_ME
RUN_REPLICATION_ENABLED=1

# ─── Object storage (Garage) ─────────────────────────────────────────────────
# Stores task run payloads and outputs.
# Credentials are read from makerops-core/infrastructure/garage/.env by start.sh.
# Garage must be running before start.sh is executed.
OBJECT_STORE_BASE_URL=http://host.docker.internal:3900
OBJECT_STORE_ACCESS_KEY_ID=GENERATE_ME
OBJECT_STORE_SECRET_ACCESS_KEY=GENERATE_ME

# ─── Container registry ───────────────────────────────────────────────────────
# Stores deployed task worker images. Exposed on localhost:5000.
# NOTE: Docker daemon must allow insecure registry at localhost:5000.
#       Add to /etc/docker/daemon.json: { "insecure-registries": ["localhost:5000"] }
DOCKER_REGISTRY_URL=localhost:5000
DOCKER_REGISTRY_NAMESPACE=trigger
DOCKER_REGISTRY_USERNAME=registry
DOCKER_REGISTRY_PASSWORD=GENERATE_ME

# ─── App secrets — NEVER change after first run ───────────────────────────────
# Changing ENCRYPTION_KEY makes all stored encrypted data unreadable.
# Changing MAGIC_LINK_SECRET invalidates all outstanding login links.
# Changing SESSION_SECRET logs out all active users.
# See: docs/env-conventions.md
MAGIC_LINK_SECRET=GENERATE_ME
SESSION_SECRET=GENERATE_ME
ENCRYPTION_KEY=GENERATE_ME
# Shared secret between webapp and supervisor (replaces PROVIDER_SECRET + COORDINATOR_SECRET):
MANAGED_WORKER_SECRET=GENERATE_ME

# ─── Concurrency limits ───────────────────────────────────────────────────────
# Maximum concurrent task runs across all environments in an organisation.
DEFAULT_ORG_EXECUTION_CONCURRENCY_LIMIT=300
# Maximum concurrent task runs within a single environment (prod/staging/dev).
DEFAULT_ENV_EXECUTION_CONCURRENCY_LIMIT=100

# ─── Data paths (optional) ────────────────────────────────────────────────────
# Override where Docker stores persistent data on the host.
# Leave unset to use the defaults shown below.
#TRIGGERDEV_DB_DATA_PATH=./data/postgres
#TRIGGERDEV_REDIS_DATA_PATH=./data/redis
#TRIGGERDEV_CLICKHOUSE_DATA_PATH=./data/clickhouse
#TRIGGERDEV_REGISTRY_DATA_PATH=./data/registry

# ─── Email (optional) ────────────────────────────────────────────────────────
# Without these, magic login links are printed to the webapp container logs.
# Set FROM_EMAIL + RESEND_API_KEY to deliver login links and alerts by email.
# Docs: https://trigger.dev/docs/open-source-self-hosting
#FROM_EMAIL=
#REPLY_TO_EMAIL=
#RESEND_API_KEY=
#ALERT_FROM_EMAIL=
#ALERT_RESEND_API_KEY=

# ─── Auth restrictions (optional) ────────────────────────────────────────────
# Restrict signups to specific email addresses (regex).
# WHITELISTED_EMAILS: only matching addresses can log in.
# ADMIN_EMAILS: comma-separated addresses granted admin privileges on signup.
# Example: WHITELISTED_EMAILS=you@example\.com|colleague@example\.com
#WHITELISTED_EMAILS=
#ADMIN_EMAILS=

# ─── GitHub OAuth (optional) ─────────────────────────────────────────────────
# Enables "Sign in with GitHub" as an alternative to magic links.
# Create an OAuth App at: https://github.com/settings/developers
# Callback URL: http://<TRIGGER_DOMAIN>/auth/github/callback
#AUTH_GITHUB_CLIENT_ID=
#AUTH_GITHUB_CLIENT_SECRET=
