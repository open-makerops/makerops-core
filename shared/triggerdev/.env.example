# ─── trigger.dev — Background Jobs & Workflow Execution ──────────────────────
# App secrets are auto-generated by start.sh on first run and written back here.
# Do not share this file.
# See: docs/env-conventions.md

# ─── Image versions ───────────────────────────────────────────────────────────
# Pin component versions together for reproducibility.
# See: https://github.com/triggerdotdev/trigger.dev/releases
TRIGGER_IMAGE_TAG=v3
POSTGRES_IMAGE_TAG=16
REDIS_IMAGE_TAG=7
ELECTRIC_IMAGE_TAG=latest

# ─── Host port ────────────────────────────────────────────────────────────────
LISTEN_PORT=3040

# ─── Application URL ──────────────────────────────────────────────────────────
# Must match the URL used in the browser.
# For remote/tunnel access, change TRIGGER_DOMAIN to the public host.
TRIGGER_PROTOCOL=http
TRIGGER_DOMAIN=localhost:3040

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_DB=trigger
# Password auto-generated on first run:
POSTGRES_PASSWORD=                        # auto-generated by start.sh on first run

# DATABASE_URL and DIRECT_URL are derived by start.sh from the values above.
# Both point to the same host; Prisma uses DIRECT_URL for migrations.
DATABASE_URL=                             # derived by start.sh on first run
DIRECT_URL=                               # derived by start.sh on first run

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# TLS is disabled because Redis runs on an internal Docker network.
REDIS_TLS_DISABLED=true

# ─── App secrets — NEVER change after first run ───────────────────────────────
# Changing ENCRYPTION_KEY makes all stored encrypted data unreadable.
# Changing MAGIC_LINK_SECRET invalidates all outstanding login links.
# Changing SESSION_SECRET logs out all active users.
# See: docs/env-conventions.md
MAGIC_LINK_SECRET=                        # auto-generated by start.sh on first run
SESSION_SECRET=                           # auto-generated by start.sh on first run
ENCRYPTION_KEY=                           # auto-generated by start.sh on first run

# ─── Worker secrets ───────────────────────────────────────────────────────────
# Shared secrets between the webapp, docker-provider, and coordinator.
# Auto-generated on first run.
PROVIDER_SECRET=                          # auto-generated by start.sh on first run
COORDINATOR_SECRET=                       # auto-generated by start.sh on first run

# ─── Runtime ──────────────────────────────────────────────────────────────────
# Internal Remix app port — do not change; it is not exposed to the host.
PORT=3030
REMIX_APP_PORT=3030
NODE_ENV=production
RUNTIME_PLATFORM=docker-compose
V3_ENABLED=true
# Disable internal OpenTelemetry tracing (reduces noise in local deployments).
INTERNAL_OTEL_TRACE_DISABLED=1
INTERNAL_OTEL_TRACE_LOGGING_ENABLED=0

# ─── Concurrency limits ───────────────────────────────────────────────────────
# Maximum concurrent job runs across all environments in an organisation.
DEFAULT_ORG_EXECUTION_CONCURRENCY_LIMIT=300
# Maximum concurrent job runs within a single environment (prod/staging/dev).
DEFAULT_ENV_EXECUTION_CONCURRENCY_LIMIT=100

# ─── Data paths (optional) ───────────────────────────────────────────────────
# Override where Docker stores persistent data on the host.
# Leave unset to use the defaults shown below.
# See: docs/env-conventions.md
#TRIGGERDEV_DB_DATA_PATH=./data/postgres
#TRIGGERDEV_REDIS_DATA_PATH=./data/redis

# ─── Email (optional) ────────────────────────────────────────────────────────
# Without these, magic login links are printed to the webapp container logs.
# Set FROM_EMAIL + RESEND_API_KEY to deliver login links and alerts by email.
# Docs: https://trigger.dev/docs/open-source-self-hosting
# See: docs/env-conventions.md for SMTP guidance.
#FROM_EMAIL=
#REPLY_TO_EMAIL=
#RESEND_API_KEY=
#ALERT_FROM_EMAIL=
#ALERT_RESEND_API_KEY=

# ─── Auth restrictions (optional) ────────────────────────────────────────────
# Restrict signups to specific email addresses (regex).
# WHITELISTED_EMAILS: only matching addresses can log in.
# ADMIN_EMAILS: comma-separated addresses granted admin privileges on signup.
# Example: WHITELISTED_EMAILS=you@example\.com|colleague@example\.com
#WHITELISTED_EMAILS=
#ADMIN_EMAILS=

# ─── GitHub OAuth (optional) ─────────────────────────────────────────────────
# Enables "Sign in with GitHub" as an alternative to magic links.
# Create an OAuth App at: https://github.com/settings/developers
# Callback URL: http://<TRIGGER_DOMAIN>/auth/github/callback
#AUTH_GITHUB_CLIENT_ID=
#AUTH_GITHUB_CLIENT_SECRET=
