# ─── FreeScout — Help Desk / Shared Inbox ────────────────────────────────────
# Review and update passwords before first run.
# ADMIN_EMAIL and ADMIN_PASS are used to create the admin account on first start
# and cannot be changed here after the database is initialised.
# See: docs/env-conventions.md

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme

# ─── Admin account (created on first start) ───────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=changeme

# ─── Application ──────────────────────────────────────────────────────────────
# SITE_URL must match the URL used to reach the application.
# Changing this after first start requires updating APP_URL in the database.
SITE_URL=http://localhost:8095

# Host port for the FreeScout web UI.
FREESCOUT_PORT=8095

# ─── Locale / timezone ────────────────────────────────────────────────────────
# See: docs/env-conventions.md
TZ=America/Chicago

# ─── Application behaviour (optional) ────────────────────────────────────────
# Display PHP errors in the browser — set TRUE only for debugging.
#DISPLAY_ERRORS=FALSE

# Automatically apply application updates on container start.
# FALSE is recommended for production; update manually via the UI or by
# pulling a new image version.
#ENABLE_AUTO_UPDATE=FALSE

# ─── Data paths (optional) ───────────────────────────────────────────────────
# Override where Docker stores persistent data on the host.
# Leave unset to use the defaults shown below.
# See: docs/env-conventions.md
#FREESCOUT_DB_DATA_PATH=./data/db
#FREESCOUT_APP_DATA_PATH=./data/app
#FREESCOUT_LOGS_PATH=./data/logs

# ─── Mail / SMTP (optional) ───────────────────────────────────────────────────
# Required to send and receive support emails via FreeScout.
# Without SMTP, outbound notifications will not be delivered.
# Docs: https://github.com/tiredofit/docker-freescout#mail-settings
# See: docs/env-conventions.md for SMTP guidance.
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_ENCRYPTION=tls
#SMTP_USERNAME=
#SMTP_PASSWORD=
#MAIL_FROM_ADDRESS=support@example.com
#MAIL_FROM_NAME=Support
