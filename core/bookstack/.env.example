# ─── BookStack — Wiki & Documentation ────────────────────────────────────────
# APP_KEY is auto-generated by the container on first start and written back
# here. Do not change it after first run — it encrypts stored data.
# Default admin account created on first run: admin@admin.com / password
# Change credentials through the BookStack UI after setup.
# See: docs/env-conventions.md

# ─── Image ────────────────────────────────────────────────────────────────────
# Pin to a specific tag for reproducibility, e.g. version-24.05.4
# See: https://hub.docker.com/r/linuxserver/bookstack/tags
#BOOKSTACK_TAG=latest

# ─── Application ──────────────────────────────────────────────────────────────
# APP_URL must match the URL used to reach BookStack (including port).
# Changing this after first run requires updating the URL in the database.
APP_URL=http://localhost:6875

# Laravel encryption key — auto-generated on first start.
# WARNING: Changing this after first run will corrupt all encrypted data.
APP_KEY=                                  # auto-generated on first start

# ─── Locale / timezone ────────────────────────────────────────────────────────
# See: docs/env-conventions.md
TZ=America/Chicago

# ─── File ownership (LinuxServer.io) ─────────────────────────────────────────
# UID/GID the application process runs as inside the container.
# Default 1000:1000 matches the first non-root user on most Linux hosts.
# See: docs/env-conventions.md
#PUID=1000
#PGID=1000

# ─── Database ─────────────────────────────────────────────────────────────────
# Passwords must match across both variables; change before first run.
# DB_HOST, DB_USERNAME, DB_DATABASE are fixed to the container name and
# cannot be changed without modifying docker-compose.yml.
DB_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme

# ─── Data paths (optional) ───────────────────────────────────────────────────
# Override where Docker stores persistent data on the host.
# Leave unset to use the defaults shown below.
# See: docs/env-conventions.md
#BOOKSTACK_DB_DATA_PATH=./db_data
#BOOKSTACK_APP_DATA_PATH=./config

# ─── Mail / SMTP (optional) ───────────────────────────────────────────────────
# Without SMTP, password resets and notifications are unavailable.
# Uncomment and configure to enable email delivery.
# See: docs/env-conventions.md for SMTP guidance.
# Docs: https://www.bookstackapp.com/docs/admin/email-webhooks/
#MAIL_DRIVER=smtp
#MAIL_HOST=smtp.example.com
#MAIL_PORT=587
#MAIL_USERNAME=
#MAIL_PASSWORD=
#MAIL_ENCRYPTION=tls
#MAIL_FROM_ADDRESS=bookstack@example.com
#MAIL_FROM_NAME=BookStack
