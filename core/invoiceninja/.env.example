# ─── Invoice Ninja — Accounting & Invoicing ───────────────────────────────────
# Secrets marked GENERATE_ME are auto-generated by start.sh on first run.
# APP_KEY is derived via `openssl rand` on first run — do not change it after
# first startup or you will lose access to encrypted data (tokens, credentials).
# Do not share this file.
# See: docs/env-conventions.md

# ─── Image version ────────────────────────────────────────────────────────────
# Pin to a specific release, e.g. 5.13.18, for reproducibility.
# See: https://hub.docker.com/r/invoiceninja/invoiceninja-debian/tags
IN_TAG=latest

# ─── Host port ────────────────────────────────────────────────────────────────
# Port exposed on localhost.
LISTEN_PORT=8092

# ─── Application ──────────────────────────────────────────────────────────────
# APP_URL must match the URL you use to access Invoice Ninja (including port).
APP_URL=http://localhost:8092
APP_ENV=production
APP_DEBUG=false

# Accept connections from non-HTTPS origins. Set to true behind a TLS proxy.
REQUIRE_HTTPS=false

# Trust all proxies — safe for a single-host Docker deployment.
TRUSTED_PROXIES=*

# PDF generation: snappdf uses the bundled Chromium inside the container.
# Do not change unless you know what you're doing.
PHANTOMJS_PDF_GENERATION=false
PDF_GENERATOR=snappdf

# Required by the app to locate the correct storage driver inside the
# debian-based Docker image.
FILESYSTEM_DISK=debian_docker
IS_DOCKER=true
SCOUT_DRIVER=null

# ─── Laravel encryption key (auto-generated on first run) ─────────────────────
# Format: base64:<44-char base64 string>
# WARNING: Changing this after first run will corrupt all encrypted data.
# See: docs/env-conventions.md
APP_KEY=                                  # auto-generated by start.sh on first run

# ─── Sessions / Cache / Queue — all backed by Redis ───────────────────────────
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=in-redis
REDIS_PORT=6379
# No password on internal Redis instance:
REDIS_PASSWORD=null

# ─── MySQL ────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=in-db
DB_PORT=3306
DB_DATABASE=ninja
DB_USERNAME=ninja
# Passwords auto-generated on first run:
DB_PASSWORD=                              # auto-generated by start.sh on first run
DB_ROOT_PASSWORD=                         # auto-generated by start.sh on first run

# ─── Initial admin account ────────────────────────────────────────────────────
# Set before first startup. After the account is created these can be cleared.
# Default (if blank): admin@example.com / changeme!
# See: docs/env-conventions.md
IN_USER_EMAIL=admin@example.com
IN_PASSWORD=                              # auto-generated by start.sh on first run

# ─── Data paths (optional) ───────────────────────────────────────────────────
# Override where Docker stores persistent data on the host.
# Leave unset to use the defaults shown below.
# See: docs/env-conventions.md
#INVOICENINJA_DB_DATA_PATH=./data/mysql
#INVOICENINJA_REDIS_DATA_PATH=./data/redis
#INVOICENINJA_PUBLIC_PATH=./data/public
#INVOICENINJA_STORAGE_PATH=./data/storage

# ─── Mail / SMTP (optional) ───────────────────────────────────────────────────
# Default: write all mail to the container log (no external SMTP required).
# To send real email, set MAIL_MAILER=smtp and fill in the details below.
# Docs: https://invoiceninja.github.io/en/self-host-configuration/#email-settings
# See: docs/env-conventions.md for SMTP guidance.
MAIL_MAILER=log
#MAIL_MAILER=smtp
#MAIL_HOST=smtp.example.com
#MAIL_PORT=587
#MAIL_USERNAME=
#MAIL_PASSWORD=
#MAIL_ENCRYPTION=tls
#MAIL_FROM_ADDRESS=invoiceninja@example.com
#MAIL_FROM_NAME=Invoice Ninja

# ─── Banking integrations (optional) ─────────────────────────────────────────
# GoCardless / Nordigen — open banking API for automatic bank feeds.
# Obtain credentials at: https://developer.gocardless.com/bank-account-data/quick-start-guide
# Leave blank to disable.
NORDIGEN_SECRET_ID=
NORDIGEN_SECRET_KEY=
