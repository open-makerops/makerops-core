# ─── ComfyUI — FLUX.1 Image Generation ───────────────────────────────────────
# Requires NVIDIA Container Toolkit on the host before starting.
# See: ai/README.md for prerequisite installation instructions.
# Docs: https://github.com/ai-dock/comfyui

# ─── ComfyUI ──────────────────────────────────────────────────────────────────
# Port ComfyUI listens on (host side).
COMFYUI_PORT_HOST=8188

# Extra startup arguments passed to the ComfyUI process.
# Common options: --highvram (keep model loaded), --lowvram, --cpu
# Leave empty for default behavior (auto-detected VRAM mode).
COMFYUI_ARGS=

# Automatically pull the latest ComfyUI commit on each container start.
# Set to true only if you want rolling updates; false is safer for production use.
AUTO_UPDATE=false

# Pin ComfyUI to a specific branch, tag, or commit hash.
# Leave empty to use the version baked into the image.
#COMFYUI_REF=

# ─── Service Portal ───────────────────────────────────────────────────────────
# Port for the ai-dock service portal (logs, system info, process control).
COMFYUI_SERVICEPORTAL_PORT_HOST=1111

# ─── Authentication ───────────────────────────────────────────────────────────
# All web services (ComfyUI, service portal) are password-protected by default.
# WEB_PASSWORD is auto-generated by start.sh on first run.
WEB_ENABLE_AUTH=true
WEB_USER=user
WEB_PASSWORD=GENERATE_ME

# ─── Models ───────────────────────────────────────────────────────────────────
# Hugging Face token — required to download FLUX.1-dev (gated model).
# Without a token, the provisioning script falls back to FLUX.1-schnell (ungated).
# Obtain at: https://huggingface.co/settings/tokens
# Accept the FLUX.1-dev license at: https://huggingface.co/black-forest-labs/FLUX.1-dev
HF_TOKEN=

# CivitAI API key — optional, enables downloads of gated CivitAI models.
# Obtain at: https://civitai.com/user/account
CIVITAI_TOKEN=

# ─── Provisioning ─────────────────────────────────────────────────────────────
# Script executed once on first container start to download models and custom nodes.
# The flux.sh script downloads:
#   - CLIP models: clip_l.safetensors, t5xxl_fp16.safetensors
#   - VAE:         ae.safetensors
#   - UNET:        flux1-dev.safetensors  (requires HF_TOKEN + license)
#              or  flux1-schnell.safetensors (no token required)
# Total download size is approximately 25 GB. Allow 10–30 minutes on first start.
# After first run, set this to empty to skip provisioning on subsequent starts.
PROVISIONING_SCRIPT=https://raw.githubusercontent.com/ai-dock/comfyui/main/config/provisioning/flux.sh

# ─── Data path (optional) ────────────────────────────────────────────────────
# Host path for the ComfyUI workspace (models, outputs, configs, custom nodes).
# FLUX models alone are ~25 GB. Override with an absolute path on a larger disk.
# Leave unset to use the default shown below.
# See: docs/env-conventions.md
COMFYUI_WORKSPACE_PATH=./data/workspace

# ─── Remote access ────────────────────────────────────────────────────────────
# Cloudflare quick tunnels create ephemeral public URLs for web services.
# Disabled here — this stack uses wg-easy for remote access instead.
CF_QUICK_TUNNELS=false

# IP or hostname used in service portal direct links. Keep as localhost unless
# you are accessing this host by a different address on your network.
DIRECT_ADDRESS=localhost

# ─── SSH (optional) ───────────────────────────────────────────────────────────
# The container includes an SSH server. Expose by uncommenting and adding the
# port to the ports section in docker-compose.yml.
#SSH_PORT_HOST=22

# Public key for SSH authentication (paste the full pubkey value).
#SSH_PUBKEY=

# ─── Timezone ─────────────────────────────────────────────────────────────────
TZ=America/Chicago
