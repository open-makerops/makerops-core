# ─── Ollama — Local LLM Inference Server ─────────────────────────────────────
# Requires NVIDIA Container Toolkit on the host before starting.
# See: ai/README.md for prerequisite installation instructions.
# Docs: https://github.com/ollama/ollama/blob/main/docs/faq.md

# ─── Network ──────────────────────────────────────────────────────────────────
# Address Ollama listens on. 0.0.0.0 exposes the API on all interfaces.
# Change to 127.0.0.1 to restrict access to localhost only.
OLLAMA_HOST=0.0.0.0

# ─── Data path (optional) ────────────────────────────────────────────────────
# Path on the host where downloaded models are stored.
# Change to a path on a large disk if the default location is space-constrained.
# Leave unset to use the default shown below.
# See: docs/env-conventions.md
OLLAMA_DATA_PATH=./data/models

# ─── Model loading (optional) ────────────────────────────────────────────────
# How many model instances to keep loaded in VRAM simultaneously.
# Default: 1. Increase if you need multiple models ready without reload delay.
#OLLAMA_MAX_LOADED_MODELS=1

# How long to keep a model loaded in VRAM after the last request.
# Accepts Go duration strings: 5m, 1h, -1 (keep forever), 0 (unload immediately).
# Default: 5m
#OLLAMA_KEEP_ALIVE=5m

# Maximum number of requests that can be queued while a model is loading.
# Requests beyond this limit are rejected with HTTP 503.
# Default: 512
#OLLAMA_MAX_QUEUE=512

# Number of requests a single model instance processes concurrently.
# Higher values improve throughput on large GPUs at the cost of per-request latency.
# Default: determined automatically based on available VRAM.
#OLLAMA_NUM_PARALLEL=1

# ─── GPU / performance (optional) ────────────────────────────────────────────
# Enable Flash Attention for supported models (reduces VRAM usage, improves speed).
# Set to 1 to enable. Requires a compatible GPU and model.
#OLLAMA_FLASH_ATTENTION=0

# ─── API access (optional) ───────────────────────────────────────────────────
# Comma-separated list of origins allowed to make browser requests to the API.
# Useful when embedding Ollama in a web app that runs on a different port.
# Default: allows requests from localhost and the Ollama app.
# Example: OLLAMA_ORIGINS=http://localhost:3000,https://myapp.example.com
#OLLAMA_ORIGINS=

# ─── Debugging (optional) ────────────────────────────────────────────────────
# Set to 1 to enable verbose debug logging (model loading, GPU ops, requests).
#OLLAMA_DEBUG=0
