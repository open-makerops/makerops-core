# ─── wg-easy — WireGuard VPN with Web UI ─────────────────────────────────────
# Edit before first start. After the admin account and WireGuard config are
# persisted to the Docker volume on first run, changes to INIT_* vars have
# no further effect (the config lives in the volume, not here).
# See: docs/env-conventions.md

# ─── Ports ────────────────────────────────────────────────────────────────────
# UDP port WireGuard clients connect to on the host.
WG_UDP_PORT=51820

# TCP port for the web management UI on the host.
WG_UI_PORT=8820

# ─── Public hostname ──────────────────────────────────────────────────────────
# The public IP address or DNS hostname that VPN clients will connect to.
# Used in generated client config files. Must be reachable from the internet.
# Corresponds to the WG_HOST environment variable passed to wg-easy.
WG_HOST=vpn.yourdomain.com

# ─── First-run unattended setup ───────────────────────────────────────────────
# Set INIT_ENABLED=true and fill in ALL remaining INIT_* vars to skip the
# interactive setup wizard on first start.
#
# After the first successful start the admin account and WireGuard config are
# persisted to the Docker volume. You can then set INIT_ENABLED=false and
# clear INIT_PASSWORD to avoid re-exposing the credential.
#
# All INIT_* variables must be provided together when INIT_ENABLED=true.

INIT_ENABLED=false
INIT_USERNAME=admin
INIT_PASSWORD=changeme

# Public IP address or hostname clients connect to (same value as WG_HOST).
INIT_HOST=vpn.yourdomain.com

# UDP port WireGuard listens on (must match WG_UDP_PORT above).
INIT_PORT=51820

# DNS servers pushed to VPN clients.
# Use the host gateway IP (e.g. 10.8.0.1) to route DNS over the tunnel.
INIT_DNS=1.1.1.1,8.8.8.8

# Internal VPN subnet assigned to clients.
INIT_IPV4_CIDR=10.8.0.0/24
INIT_IPV6_CIDR=fd42::/64

# IP routes pushed to clients.
# 0.0.0.0/0,::/0 = full tunnel (all traffic routed through VPN).
# Use a narrower CIDR (e.g. 192.168.1.0/24) for split-tunnel access only.
INIT_ALLOWED_IPS=0.0.0.0/0,::/0

# ─── Data paths (optional) ───────────────────────────────────────────────────
# Override where Docker stores WireGuard config and keys on the host.
# Leave unset to use the default shown below.
# See: docs/env-conventions.md
#WGEASY_DATA_PATH=./data/wireguard
