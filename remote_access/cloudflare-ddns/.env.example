# ─── cloudflare-ddns — Dynamic DNS Updater ───────────────────────────────────
# Keeps Cloudflare DNS A/AAAA records in sync with your current public IP.
# The container runs on the host network and requires no ports to be opened.
# Docs: https://github.com/timothyjmiller/cloudflare-ddns

# ─── Required ─────────────────────────────────────────────────────────────────
# API token with Zone:DNS:Edit permission for the target zone(s).
# Create one at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN_HERE

# Comma-separated list of domains to keep updated (sets both A and AAAA records).
# Example: DOMAINS=home.example.com,api.example.com
DOMAINS=your.domain.example.com

# ─── IPv4 / IPv6 split (optional) ────────────────────────────────────────────
# Use IP4_DOMAINS / IP6_DOMAINS instead of DOMAINS to target specific record
# types per domain. When set, they override DOMAINS for their respective type.
#IP4_DOMAINS=
#IP6_DOMAINS=

# ─── IPv6 detection method (optional) ────────────────────────────────────────
# How to detect the host's public IPv6 address.
# Options:
#   cloudflare.trace  — query Cloudflare's trace endpoint (default)
#   none              — disable AAAA record updates entirely
#IP6_PROVIDER=cloudflare.trace

# ─── Cloudflare proxy (optional) ─────────────────────────────────────────────
# Set to true to enable the Cloudflare proxy (orange-cloud) on updated records.
# When proxied, the real IP is hidden behind Cloudflare's CDN.
# WARNING: Proxying breaks direct VPN/SSH connections to the host.
#PROXIED=false

# ─── Update schedule (optional) ──────────────────────────────────────────────
# How often to check and update DNS records.
# Accepts Go duration strings (e.g. 5m, 1h) or cron expressions.
#UPDATE_CRON=@every 5m

# ─── DNS TTL (optional) ───────────────────────────────────────────────────────
# Time-to-live for DNS records in seconds. 1 = Cloudflare automatic TTL.
# Ignored when PROXIED=true (Cloudflare forces TTL=1 for proxied records).
#TTL=1

# ─── Cleanup on stop (optional) ──────────────────────────────────────────────
# When set to true, DNS records are deleted when the container stops.
# Useful for dynamic/ephemeral deployments; leave false for always-on hosts.
#DELETE_ON_STOP=false
