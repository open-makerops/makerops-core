# ─── lan-dns — LAN Hostname Resolution ───────────────────────────────────────
# Runs a dnsmasq DNS server so edge computers on the LAN can reach services
# by name (e.g. n8n.central.home) instead of by IP and port.

# ─── Host identity ────────────────────────────────────────────────────────────
# The name used as the domain portion of service hostnames.
# Must match the computer's actual LAN hostname or any alias you choose.
# Example: a host named "central" produces n8n.central.home, outline.central.home …
HOST_NAME=central

# LAN IP address of this machine — the address dnsmasq will answer with.
# Find it with: ip route get 1 | awk '{print $7; exit}'
# Must be a static LAN address (see README for how to set a static IP).
HOST_LAN_IP=192.168.1.100

# ─── DNS ──────────────────────────────────────────────────────────────────────
# The private TLD appended to HOST_NAME to form the service domain.
# Safe choices: lan, home, internal, makerops
# DO NOT use: local (conflicts with mDNS/Bonjour), or any real public TLD.
LAN_TLD=home

# Host port dnsmasq listens on. Standard DNS is 53.
# Change only if port 53 is already occupied (see README).
DNS_PORT=53

# ─── Upstream DNS ─────────────────────────────────────────────────────────────
# Public resolvers forwarded to for all queries not matching HOST_NAME.LAN_TLD.
UPSTREAM_DNS_1=1.1.1.1
UPSTREAM_DNS_2=8.8.8.8
