# ─── lan-dns (Windows) — LAN Hostname Resolution ─────────────────────────────
# Runs CoreDNS as a native Windows process so LAN clients can reach services
# by name (e.g. n8n.central.home) instead of by IP and port.
# No Docker or WSL2 required.

# ─── Host identity ────────────────────────────────────────────────────────────
# The name used as the domain portion of service hostnames.
# Example: a host named "central" produces n8n.central.home, outline.central.home
HOST_NAME=central

# LAN IP address of this machine — the address CoreDNS will answer with.
# Find it with: (Get-NetIPAddress -AddressFamily IPv4 | Where-Object {$_.IPAddress -notlike '127.*' -and $_.IPAddress -notlike '169.*'}).IPAddress
# Must be a static LAN address (see README for how to set a static IP).
HOST_LAN_IP=192.168.1.100

# ─── DNS ──────────────────────────────────────────────────────────────────────
# The private TLD appended to HOST_NAME to form the service domain.
# Safe choices: lan, home, internal, makerops
# DO NOT use: local (conflicts with mDNS/Bonjour), or any real public TLD.
LAN_TLD=home

# Host port CoreDNS listens on. Standard DNS is 53.
# Change only if port 53 cannot be freed (see README).
DNS_PORT=53

# ─── Upstream DNS ─────────────────────────────────────────────────────────────
# Public resolvers CoreDNS forwards to for all queries not matching HOST_NAME.LAN_TLD.
UPSTREAM_DNS_1=1.1.1.1
UPSTREAM_DNS_2=8.8.8.8
