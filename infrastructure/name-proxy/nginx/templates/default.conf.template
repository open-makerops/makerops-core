# Sets Connection header correctly for mixed WebSocket / plain-HTTP traffic.
map $http_upgrade $connection_upgrade {
    default  upgrade;
    ''       close;
}

# Shared proxy settings — applied to all server blocks via http-context inheritance.
proxy_http_version   1.1;
proxy_set_header     Upgrade            $http_upgrade;
proxy_set_header     Connection         $connection_upgrade;
proxy_set_header     Host               $host;
proxy_set_header     X-Real-IP          $remote_addr;
proxy_set_header     X-Forwarded-For    $proxy_add_x_forwarded_for;
proxy_set_header     X-Forwarded-Proto  $scheme;
proxy_read_timeout   300s;
client_max_body_size 100m;

# ── n8n — Workflow Automation ─────────────────────────────────────────────────
server {
    listen      80;
    server_name n8n.localhost ~^n8n\..+;
    location / { proxy_pass http://host.docker.internal:${N8N_PORT}; }
}

