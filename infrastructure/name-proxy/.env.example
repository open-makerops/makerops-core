# ─── name-proxy — Subdomain Reverse Proxy ────────────────────────────────────
# Maps *.localhost subdomains to the host ports where each service listens.
# Values here must match the host ports configured in each service's own .env.

# ─── Proxy ────────────────────────────────────────────────────────────────────
# Host port the proxy listens on. 80 gives clean http://service.localhost URLs.
PROXY_PORT=80

# ─── Service ports ────────────────────────────────────────────────────────────
# Update a value only if you changed the corresponding service's host port.

# shared/n8n         — N8N_PORT_HOST
N8N_PORT=5678

# shared/outline     — OUTLINE_PORT_HOST
OUTLINE_PORT=3000

# shared/plane       — LISTEN_HTTP_PORT
PLANE_PORT=8100

# shared/triggerdev  — LISTEN_PORT
TRIGGERDEV_PORT=3040

# sales/freescout    — FREESCOUT_PORT
FREESCOUT_PORT=8095

# accounting/invoiceninja — LISTEN_PORT
INVOICENINJA_PORT=8092

# operations/inventree — INVENTREE_WEB_PORT
INVENTREE_PORT=8096

# ai/ollama          — (hard-coded 11434)
OLLAMA_PORT=11434

# ai/comfyui         — COMFYUI_PORT_HOST
COMFYUI_PORT=8188

# remote_access/wg-easy — WG_UI_PORT
WG_PORT=8820
