# ─── Garage — S3-Compatible Object Store ──────────────────────────────────────
# garage.toml is generated from garage.toml.example by start.sh on first run.
# Secrets (rpc_secret, admin_token, metrics_token) live in garage.toml, not here.
# See: docs/env-conventions.md

# ─── Image ────────────────────────────────────────────────────────────────────
# Pin to a specific release tag for reproducibility.
# See: https://github.com/deuxfleurs-org/garage/tags
GARAGE_VERSION=v2.3.0

# ─── S3 access credentials ────────────────────────────────────────────────────
# Key ID and secret for the default S3 key, created during first-run init.
# Written here by start.sh after initialization. Used by other services
# (e.g. Outline) to connect to the Garage S3 API.
# WARNING: Do not change these after first run — regenerating the key requires
#          re-configuring every service that uses it.
GARAGE_ACCESS_KEY_ID=                        # written on first start
GARAGE_SECRET_ACCESS_KEY=                    # written on first start

# ─── Data paths (optional) ────────────────────────────────────────────────────
# Override where Docker stores persistent data on the host.
# metadata_dir should be on fast storage; data_dir can be on a larger, slower disk.
# Leave unset to use the defaults shown below.
# See: docs/env-conventions.md
#GARAGE_META_DATA_PATH=./data/meta
#GARAGE_OBJECT_DATA_PATH=./data/objects

# ─── Logging (optional) ───────────────────────────────────────────────────────
# Rust log level for the Garage process. One of: error, warn, info, debug, trace.
#RUST_LOG=info
