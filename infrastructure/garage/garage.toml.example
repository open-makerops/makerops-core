# Garage configuration — single-node deployment
# Copied to garage.toml by start.sh on first run. GENERATE_ME placeholders
# are replaced with generated secrets. Do not add secrets to this file.

metadata_dir = "/var/lib/garage/meta"
data_dir = "/var/lib/garage/data"
db_engine = "lmdb"
replication_factor = 1

rpc_bind_addr = "[::]:3901"
rpc_public_addr = "127.0.0.1:3901"
rpc_secret = "GENERATE_ME"

[s3_api]
api_bind_addr = "[::]:3900"
s3_region = "garage"

[admin]
api_bind_addr = "[::]:3903"
admin_token = "GENERATE_ME"
metrics_token = "GENERATE_ME"
