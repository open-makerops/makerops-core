# ─── InvenTree — Inventory & Parts Management ────────────────────────────────
# Secrets marked GENERATE_ME are auto-generated by start.sh on first run.
# INVENTREE_DB_PASSWORD: PostgreSQL database password.
# INVENTREE_ADMIN_PASSWORD: initial admin password — change after first login.
# Do not share this file.
# See: docs/env-conventions.md

# ─── Image version ────────────────────────────────────────────────────────────
# Use "stable" for the latest stable release, or pin to a tag like "1.3.2".
# See: https://hub.docker.com/r/inventree/inventree/tags
INVENTREE_TAG=1.3.2

# ─── Host port ────────────────────────────────────────────────────────────────
# Port exposed on localhost.
INVENTREE_WEB_PORT=8096

# ─── Application ──────────────────────────────────────────────────────────────
# INVENTREE_SITE_URL must match the URL used to access InvenTree (including port).
# INVENTREE_CANONICAL_HOST is the host portion of SITE_URL. Caddy always forwards
# this as X-Forwarded-Host so Django's SITE_URL check passes whether the request
# arrives via name-proxy (inventree.localhost) or directly on the port.
# To use port-only access without name-proxy, set both to localhost:8096 and
# http://localhost:8096 respectively, and update INVENTREE_FRONTEND_SETTINGS below.
INVENTREE_CANONICAL_HOST=inventree.localhost
INVENTREE_SITE_URL=http://inventree.localhost

# Provides server_list in the object format the React app expects internally.
# Without this the Python backend sends server_list as [] which overwrites the
# JS hardcoded default and causes a TypeError crash before React can mount.
INVENTREE_FRONTEND_SETTINGS={"server_list": {"server-current": {"host": "http://inventree.localhost/", "name": "InvenTree"}}}

# Run database migrations and collectstatic automatically on startup.
INVENTREE_AUTO_UPDATE=True

# Enable the InvenTree plugin system.
INVENTREE_PLUGINS_ENABLED=True

# Log level — options: DEBUG | INFO | WARNING | ERROR | CRITICAL
INVENTREE_LOG_LEVEL=WARNING

# Gunicorn request timeout in seconds. Increase if large report generation times out.
INVENTREE_GUNICORN_TIMEOUT=90

# Required when running behind a reverse proxy (Caddy handles this in this stack).
INVENTREE_USE_X_FORWARDED_HOST=True
INVENTREE_USE_X_FORWARDED_PORT=True
INVENTREE_USE_X_FORWARDED_PROTO=True

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
INVENTREE_DB_ENGINE=postgresql
INVENTREE_DB_NAME=inventree
INVENTREE_DB_USER=inventree
INVENTREE_DB_HOST=inventree-db
INVENTREE_DB_PORT=5432
# Password auto-generated on first run:
INVENTREE_DB_PASSWORD=                    # auto-generated by start.sh on first run

# ─── Redis cache ──────────────────────────────────────────────────────────────
INVENTREE_CACHE_ENABLED=True
INVENTREE_CACHE_HOST=inventree-cache
INVENTREE_CACHE_PORT=6379

# ─── Initial admin account ────────────────────────────────────────────────────
# Consumed once on first run to create the admin account.
# After the account exists in the database, changes here have no effect.
# See: docs/env-conventions.md
INVENTREE_ADMIN_USER=admin
INVENTREE_ADMIN_EMAIL=admin@example.com
# Password auto-generated on first run:
INVENTREE_ADMIN_PASSWORD=                 # auto-generated by start.sh on first run

# ─── Data paths (optional) ───────────────────────────────────────────────────
# Override where Docker stores persistent data on the host.
# Leave unset to use the defaults shown below.
# See: docs/env-conventions.md
#INVENTREE_DB_DATA_PATH=./data/postgres
#INVENTREE_CACHE_DATA_PATH=./data/redis
#INVENTREE_APP_DATA_PATH=./data/inventree

# ─── Email / SMTP (optional) ─────────────────────────────────────────────────
# Required for order notifications, user invitations, and password resets.
# Docs: https://docs.inventree.org/en/latest/start/config/#email-settings
# See: docs/env-conventions.md for SMTP guidance.
#INVENTREE_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#INVENTREE_EMAIL_HOST=smtp.example.com
#INVENTREE_EMAIL_PORT=587        # 587=STARTTLS (TLS=True, SSL=False); 465=Implicit SSL (SSL=True, TLS=False)
#INVENTREE_EMAIL_USERNAME=
#INVENTREE_EMAIL_PASSWORD=
#INVENTREE_EMAIL_TLS=True        # Use with PORT=587 (STARTTLS)
#INVENTREE_EMAIL_SSL=False       # Set True and TLS=False when using PORT=465
#INVENTREE_EMAIL_SENDER=inventree@example.com
#INVENTREE_EMAIL_PREFIX=[InvenTree]

# ─── Backup (optional) ───────────────────────────────────────────────────────
# Controls how many automatic database backups are retained.
# Docs: https://docs.inventree.org/en/latest/start/config/#backup-options
#INVENTREE_BACKUP_DAYS=5
#INVENTREE_BACKUP_COUNT=10
